{
	"name": "vscode-vuejs-commander",
	"displayName": "VueJS Commander",
	"description": "VueJS Commander is a Visual Studio Code extension designed to streamline the execution of common Vue.js and Nuxt.js commands.",
	"version": "1.2.0",
	"icon": "icon.png",
	"license": "MIT",
	"publisher": "imgildev",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"vscode": "^1.102.0",
		"node": ">=22.15.1"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"cli",
		"code generator",
		"code",
		"codegen",
		"codegenerator",
		"coding",
		"command",
		"commander",
		"commands",
		"create-nuxt-app",
		"create-nuxt",
		"create-nuxtjs-app",
		"create-nuxtjs-project",
		"create-nuxtjs",
		"create",
		"deploy",
		"dev",
		"development",
		"extension",
		"generator",
		"init",
		"javascript",
		"js",
		"node",
		"nodejs",
		"npm",
		"nuxi",
		"nuxt-app",
		"nuxt.js",
		"nuxt",
		"nuxtjs-app",
		"nuxtjs-generator",
		"nuxtjs-project",
		"nuxtjs",
		"nuxtjsgenerator",
		"nuxtjsproject",
		"project",
		"server",
		"tool",
		"tools",
		"ts",
		"typescript",
		"vscode-extension",
		"vscode",
		"vue component",
		"vue file",
		"vue generator",
		"vue js colombia",
		"vue js",
		"vue project",
		"vue structure",
		"vue template",
		"vue tool",
		"vue-ts",
		"vue.js",
		"vue",
		"vuejs colombia",
		"vuejs",
		"vuejsco",
		"vuejscolombia",
		"yarn"
	],
	"homepage": "https://github.com/vuejsco/vscode-vuejs-commander",
	"repository": {
		"type": "git",
		"url": "https://github.com/vuejsco/vscode-vuejs-commander"
	},
	"bugs": {
		"url": "https://github.com/vuejsco/vscode-vuejs-commander/issues"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"l10n": "./l10n",
	"files": [
		"out",
		"package*.json",
		"README.md",
		"LICENSE",
		"icon.png",
		"schemas",
		"l10n"
	],
	"contributes": {
		"configuration": {
			"title": "VueJS Commander",
			"properties": {
				"vuejs.commander.enable": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%vuejs.commander.enable%"
				},
				"vuejs.commander.packages.defaultPackageManager": {
					"type": "string",
					"default": "npm",
					"enum": [
						"npm",
						"yarn",
						"pnpm"
					],
					"enumDescriptions": [
						"npm",
						"yarn",
						"pnpm"
					],
					"scope": "resource",
					"description": "%vuejs.commander.packages.defaultPackageManager%"
				},
				"vuejs.commander.terminal.currentWorkingDirectory": {
					"type": "string",
					"default": "",
					"scope": "resource",
					"description": "%vuejs.commander.terminal.currentWorkingDirectory%"
				},
				"vuejs.commander.terminal.hideFromUser": {
					"type": "boolean",
					"default": false,
					"scope": "resource",
					"description": "%vuejs.commander.terminal.hideFromUser%"
				}
			}
		},
		"commands": [
			{
				"command": "vuejs.commander.createProject",
				"title": "%vuejs.commander.createProject%",
				"category": "VueJS Commander"
			},
			{
				"command": "vuejs.commander.devServer",
				"title": "%vuejs.commander.devServer%",
				"category": "VueJS Commander"
			},
			{
				"command": "vuejs.commander.build",
				"title": "%vuejs.commander.build%",
				"category": "VueJS Commander"
			}
		],
		"submenus": [
			{
				"id": "vuejs.commander.submenu",
				"label": "VueJS Commander"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"submenu": "vuejs.commander.submenu",
					"group": "2_workspace",
					"when": "explorerViewletFocus && explorerResourceIsRoot"
				}
			],
			"vuejs.commander.submenu": [
				{
					"command": "vuejs.commander.createProject",
					"group": "vuejs.commander"
				},
				{
					"command": "vuejs.commander.devServer",
					"group": "vuejs.commander"
				},
				{
					"command": "vuejs.commander.build",
					"group": "vuejs.commander"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": ".vscode/settings.json",
				"url": "./schemas/config.schema.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm compile",
		"typecheck": "tsc --noEmit -p ./",
		"compile": "pnpm typecheck && rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=out/extension.js",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm compile && tsc -p ./ && pnpm lint",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "vscode-test",
		"test:unit": "mocha -r ts-node/register src/**/*.test.ts",
		"l10n:check": "node scripts/check-l10n.js",
		"nls:check": "node scripts/check-nls.js",
		"prepare": "husky",
		"release": "release-it"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@release-it/conventional-changelog": "^10.0.6",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.21",
		"@types/vscode": "^1.102.0",
		"@vscode/l10n-dev": "^0.0.35",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"autoprefixer": "^10.5.0",
		"cpy-cli": "^5.0.0",
		"esbuild": "^0.28.1",
		"glob": "^11.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"mocha": "^10.8.2",
		"release-it": "^18.1.2",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"vscode-marketplace-client": "^1.2.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {
			"diff@>=6.0.0 <8.0.3": ">=8.0.3",
			"lodash@<=4.17.23": ">=4.18.0",
			"serialize-javascript@>=5.0.0 <7.0.5": ">=7.0.5",
			"undici@>=6.0.0 <6.24.0": ">=6.24.0"
		}
	}
}
